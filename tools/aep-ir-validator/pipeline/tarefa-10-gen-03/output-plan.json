        {"binding": "license_classifications", "access": "read"}
      ],
      "outputs": [{"binding": "risk_assessment", "access": "write"}],
      "payload": {"tool": "check_copyleft_trigger", "params": {"distribution_model": "commercial", "assess": "copyleft_provision"}}
    },
    {
      "id": "node-005",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        {"binding": "parsed_sbom", "access": "read"},
        {"binding": "risk_assessment", "access": "read"}
      ],
      "outputs": [{"binding": "compliance_report", "access": "write"}],
      "payload": {"tool": "generate_report", "params": {"include": ["packages", "risks", "remediation"], "format": "compliance_audit"}}
