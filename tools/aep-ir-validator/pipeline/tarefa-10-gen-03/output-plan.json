        {"binding": "license_classifications", "access": "read"}
      ],
      "outputs": [{"binding": "usage_patterns", "access": "write"}],
      "payload": {"tool": "analyze_usage_pattern", "params": {"filter": "copyleft", "distinguish": ["linked", "aggregated"], "parallel": true}}
    },
    {
      "id": "node-004",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
