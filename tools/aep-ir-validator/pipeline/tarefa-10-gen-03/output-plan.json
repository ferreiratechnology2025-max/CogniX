      "payload": {"tool": "classify_license", "params": {"mode": "batch", "categories": ["permissive", "copyleft", "proprietary"], "flag": ["GPL-3.0", "AGPL-3.0"]}}
    },
    {
      "id": "node-003",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
