      "outputs": [{"binding": "exposure_assessment", "access": "write"}],
      "payload": {"tool": "estimate_exposure", "params": {"claims": "analyzed_claims", "revenue_data": "revenue_data"}}
    },
    {
      "id": "node-006",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        {"binding": "prior_art_results", "access": "read"},
        {"binding": "exposure_assessment", "access": "read"}
      ],
      "outputs": [{"binding": "strategy_recommendation", "access": "write"}],
      "payload": {"tool": "recommend_strategy", "params": {"validity": "prior_art_results", "exposure": "exposure_assessment", "costs": "estimated_legal_costs"}}
    }
  ],
  "edges": [
    {"source": "node-001", "target": "node-002"},
