      },
      {
        "name": "prior_art_results",
        "type": "object",
        "mutability": "mutable",
        "scope": "session",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "exposure_assessment",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
