      "payload": {"tool": "read_patent", "params": {"uri": "patent_document.uri"}}
    },
    {
      "id": "node-002",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
