      "outputs": [{"binding": "analyzed_claims", "access": "write"}],
      "payload": {"tool": "analyze_claims", "params": {"patent_text": "patent_text"}}
    },
    {
      "id": "node-003",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{"binding": "product_db", "access": "read"}],
      "outputs": [{"binding": "product_architecture", "access": "write"}],
      "payload": {"tool": "map_product_architecture", "params": {"client_id": "client-001"}}
    },
    {
      "id": "node-004",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{"binding": "analyzed_claims", "access": "read"}],
      "outputs": [{"binding": "prior_art_results", "access": "write"}],
      "payload": {"tool": "search_prior_art", "params": {"claims": "analyzed_claims", "databases": ["uspto", "epo", "wipo"]}}
    },
    {
      "id": "node-005",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        {"binding": "analyzed_claims", "access": "read"},
        {"binding": "product_architecture", "access": "read"},
        {"binding": "revenue_data", "access": "read"}
