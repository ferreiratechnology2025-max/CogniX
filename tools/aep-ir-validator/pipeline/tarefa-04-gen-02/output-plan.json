{
  "plan_header": {
    "ir_version": "1.0.0",
    "plan_id": "plan-review-court-ruling-precedent-001",
    "declared_capabilities": ["memory_rw", "tool_execution", "court_db_access", "case_db_access"],
    "declared_bindings": [
      {
        "name": "court_db",
        "type": "object",
        "mutability": "readonly",
        "scope": "persistent",
        "capability": "court_db_access",
