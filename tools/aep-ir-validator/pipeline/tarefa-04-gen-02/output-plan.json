      {
        "name": "client_cases_db",
        "type": "object",
        "mutability": "readonly",
        "scope": "persistent",
        "capability": "case_db_access",
        "default": null
      },
      {
        "name": "ruling_text",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "precedent_assessment",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "affected_cases",
        "type": "array",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": []
      },
      {
        "name": "memo_draft",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      }
    ]
  },
  "nodes": [
    {
      "id": "node-001",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "court_db_access", "memory_rw"],
      "inputs": [{"binding": "court_db", "access": "read"}],
      "outputs": [{"binding": "ruling_text", "access": "write"}],
      "payload": {"tool": "fetch_ruling", "params": {"court": "STJ", "ruling_id": "software-taxation-ISS-ICMS"}}
    },
    {
      "id": "node-002",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
