{
  "plan_header": {
    "ir_version": "1.0.0",
    "plan_id": "plan-audit-policy-mlsc-001",
    "declared_capabilities": ["memory_rw", "tool_execution"],
    "declared_bindings": [
      {
        "name": "policy_uri",
        "type": "string",
        "mutability": "readonly",
        "scope": "session",
        "capability": "memory_rw",
        "default": null
      },
      {
        "name": "regulation_uri",
        "type": "string",
        "mutability": "readonly",
        "scope": "session",
        "capability": "memory_rw",
        "default": null
      },
      {
        "name": "policy_document",
        "type": "object",
        "mutability": "readonly",
        "scope": "session",
        "capability": "memory_rw",
        "default": null
      },
      {
        "name": "regulation_text",
        "type": "object",
        "mutability": "readonly",
        "scope": "session",
        "capability": "memory_rw",
        "default": null
      },
      {
        "name": "comparison_result",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "gap_analysis",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "severity_ratings",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "recommendations",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      },
      {
        "name": "action_plan",
        "type": "object",
        "mutability": "mutable",
        "scope": "execution",
        "capability": "memory_rw",
        "default": {}
      }
    ]
  },
  "nodes": [
    {
      "id": "node-001",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{"binding": "policy_uri", "access": "read"}],
      "outputs": [{"binding": "policy_document", "access": "write"}],
      "payload": {"tool": "read_policy", "params": {"uri": "policy_uri"}}
    },
    {
      "id": "node-002",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{"binding": "regulation_uri", "access": "read"}],
      "outputs": [{"binding": "regulation_text", "access": "write"}],
      "payload": {"tool": "read_regulation", "params": {"uri": "regulation_uri"}}
    },
    {
      "id": "node-003",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        {"binding": "policy_document", "access": "read"},
        {"binding": "regulation_text", "access": "read"}
      ],
      "outputs": [{"binding": "comparison_result", "access": "write"}],
      "payload": {"tool": "compare_documents", "params": {"policy_text": "policy_document", "regulation_text": "regulation_text", "scope": "data_retention"}}
    },
    {
      "id": "node-004",
      "type": "transformation",
      "effects": ["READ", "WRITE"],
      "capabilities": ["memory_rw"],
      "inputs": [{"binding": "comparison_result", "access": "read"}],
      "outputs": [{"binding": "gap_analysis", "access": "write"}],
      "payload": {"operation": "extract_policy_gaps", "description": "Identify specific policy sections requiring revision from comparison result"}
    },
    {
      "id": "node-005",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{"binding": "gap_analysis", "access": "read"}],
      "outputs": [{"binding": "severity_ratings", "access": "write"}],
      "payload": {"tool": "assess_gap_severity", "params": {"gap": "gap_analysis"}}
    },
    {
      "id": "node-006",
      "type": "transformation",
      "effects": ["READ", "WRITE"],
      "capabilities": ["memory_rw"],
      "inputs": [
        {"binding": "gap_analysis", "access": "read"},
        {"binding": "severity_ratings", "access": "read"}
      ],
      "outputs": [{"binding": "recommendations", "access": "write"}],
      "payload": {"operation": "derive_recommendations", "description": "Generate recommended amendments based on gaps and severity"}
    },
    {
      "id": "node-007",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        {"binding": "gap_analysis", "access": "read"},
        {"binding": "recommendations", "access": "read"}
      ],
      "outputs": [{"binding": "action_plan", "access": "write"}],
      "payload": {"tool": "generate_action_plan", "params": {"gaps": "gap_analysis", "recommendations": "recommendations"}}
    }
  ],
  "edges": [
    {"source": "node-001", "target": "node-003"},
    {"source": "node-002", "target": "node-003"},
    {"source": "node-003", "target": "node-004"},
    {"source": "node-004", "target": "node-005"},
    {"source": "node-004", "target": "node-006"},
    {"source": "node-005", "target": "node-006"},
    {"source": "node-006", "target": "node-007"},
    {"source": "node-004", "target": "node-007"}
  ]
}