  "nodes": [
    {
      "id": "node-001",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{ "binding": "sbom_document", "access": "read" }],
      "outputs": [{ "binding": "parsed_packages", "access": "write" }],
      "payload": {
        "tool": "parse_sbom",
        "params": { "uri": "sbom://client/dependencies.json", "expected_count": 1247 }
      }
    },
    {
      "id": "node-002",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        { "binding": "parsed_packages", "access": "read" },
        { "binding": "license_db", "access": "read" }
      ],
      "outputs": [{ "binding": "license_classification", "access": "write" }],
      "payload": {
        "tool": "classify_license",
        "params": {
          "mode": "batch",
          "target_categories": ["permissive", "copyleft", "proprietary"],
          "flag_licenses": ["GPL-3.0", "AGPL-3.0"]
        }
      }
    },
    {
      "id": "node-003",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [{ "binding": "parsed_packages", "access": "read" }],
      "outputs": [{ "binding": "usage_patterns", "access": "write" }],
      "payload": {
        "tool": "analyze_usage_pattern",
        "params": {
          "mode": "batch",
          "distinguish": ["linked", "aggregated"],
          "distribution_model": "commercial"
        }
      }
    },
    {
      "id": "node-004",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        { "binding": "usage_patterns", "access": "read" },
        { "binding": "license_classification", "access": "read" }
      ],
      "outputs": [
        { "binding": "copyleft_triggers", "access": "write" },
        { "binding": "risk_assessment", "access": "write" }
      ],
      "payload": {
        "tool": "check_copyleft_trigger",
        "params": {
          "copyleft_focus": ["GPL-3.0", "AGPL-3.0"],
          "trigger_rule": "linking_triggers_aggregation_exempt"
        }
      }
    },
    {
      "id": "node-005",
      "type": "tool_call",
      "effects": ["CALL_TOOL", "READ", "WRITE"],
      "capabilities": ["tool_execution", "memory_rw"],
      "inputs": [
        { "binding": "parsed_packages", "access": "read" },
        { "binding": "risk_assessment", "access": "read" },
        { "binding": "copyleft_triggers", "access": "read" }
      ],
      "outputs": [{ "binding": "compliance_report", "access": "write" }],
      "payload": {
        "tool": "generate_report",
        "params": {
          "report_type": "license_compliance",
          "include_remediation": true,
          "distribution_model": "commercial"
        }
      }
    }
  ],
  "edges": [
