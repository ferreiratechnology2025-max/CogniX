# Arquivos temporários do sistema
*.tmp
*.log
*.swp
*~
.DS_Store
Thumbs.db

# Arquivos de IDE
.vscode/
.idea/
*.iml

# Dependências (caso algum projeto dentro do KOS use)
node_modules/
vendor/
__pycache__/
*.pyc

# Arquivos de ambiente
.env
.env.local
.env.*.local

# Build artifacts
*.egg-info/

# Generated indexes / databases (rebuilt by tooling, not source of truth)
aep-index.db
implementations/sqlite/aep.db

# Deprecated benchmark output (RAG comparison removed — wrong category under
# the execution-envelope model; see README). Kept locally, not versioned.
benchmark-results.json

# Volatile runtime byproducts — these embed per-run session-ids/timestamps and
# are non-deterministic. They must not be versioned in a determinism-focused
# repo. The kernel/tooling regenerates them on every run.
KERNEL/STATE.md
conformance/normative/snapshots/actual/

# The 30-plan experiment has run and been reviewed (2026-07). Track the
# reviewed final results (manifest, report, results table, generation log);
# ignore regenerable per-plan byproducts (envelope copies, validator stdout
# captures) — those are derivable from tools/aep-ir-validator/pipeline/*
# /output-plan.json, which is tracked as the real generated data.
experiment-results/*
!experiment-results/manifest.json
!experiment-results/REPORT.md
!experiment-results/results-table.csv
!experiment-results/generation-log.jsonl

# Regenerable envelope byproduct (canonical plan + checksum), derivable from
# the tracked output-plan.json in the same pipeline folder.
tools/aep-ir-validator/pipeline/*/envelope-temp.json